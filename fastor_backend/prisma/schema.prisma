datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Employee {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  leads     Enquiry[] @relation("ClaimedLeads")
  createdAt DateTime  @default(now())
}

model Enquiry {
  id          Int       @id @default(autoincrement())
  name        String
  email       String
  course      String
  phone       String?
  createdAt   DateTime  @default(now())
  claimedBy   Employee? @relation("ClaimedLeads", fields: [claimedById], references: [id])
  claimedById Int?
}
